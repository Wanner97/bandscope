{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=BandScope;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "JwtSettings": {
    "Key": "Set your JWT Token Key here while your project is in development",
    "Issuer": "BandScope",
    "Audience": "BandScope",
    "ExpiresInMinutes": 60
  },
  "TheAudioDb": {
    "BaseUrl": "https://www.theaudiodb.com/api/v1/json",
    "ApiKey": "Set your API Key here while your project is in development"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": "Warning",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}